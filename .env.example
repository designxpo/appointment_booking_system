# ─────────────────────────────────────────────────────────────
# Slotnest environment configuration
# Copy to `.env.local` and fill in real values. Never commit secrets.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (the AI receptionist engine, "Entropy")
ANTHROPIC_API_KEY=sk-ant-your-key
# Default model for the receptionist agent
ANTHROPIC_MODEL=claude-sonnet-4-6

# Resend (transactional email — appointment confirmations)
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=bookings@yourdomain.com
# Where the marketing "Book a call" / contact form sends enquiries.
# Falls back to RESEND_FROM_EMAIL if unset.
CONTACT_EMAIL=hello@yourdomain.com

# Owner console (/owner) — super-admin access, comma-separated emails.
# The signed-in user must match one of these to manage clients & tiers.
OWNER_EMAILS=you@yourdomain.com

# Support / sales contact used by the client "Request upgrade" flow
# (subscriptions are activated manually from the owner console).
NEXT_PUBLIC_SUPPORT_EMAIL=sales@slotnest.ai
# Optional WhatsApp number in international format WITHOUT '+', e.g. 919876543210.
# If set, upgrade requests open WhatsApp instead of email.
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Tenant root domain — sites are served at <subdomain>.<root>. Leave blank in dev.
NEXT_PUBLIC_ROOT_DOMAIN=

# Shared secret for cron endpoints (/api/cron/*). Set the same value on your scheduler.
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev-only: when "true", bypass auth and serve in-memory sample data so you can
# click through the dashboard with no backend. Force-disabled in production.
# Leave unset/false for real usage.
NEXT_PUBLIC_DEV_MOCK=false
